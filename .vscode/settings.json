{
    "al.enableCodeAnalysis": true,
    "al.codeAnalyzers": [
        "${CodeCop}",
        "${PerTenantExtensionCop}",
        "${UICop}"
    ],
    "[al]": {
        "editor.wordBasedSuggestions": "allDocuments",
        "editor.suggestSelection": "first",
        "editor.formatOnSave": true,
        "editor.codeLens": true,
        "editor.semanticHighlighting.enabled": true,
        "editor.fontSize": 12,
    },
    //"al.outputAnalyzerStatistics": true,
    "al.backgroundCodeAnalysis": true,
    "al.enableCodeActions": true,
    "al.packageCachePath": "./.alpackages",
    "al-test-runner.sendDebugTelemetry": false,
    "al.compilationOptions": {
        "generateReportLayout": true
    },
    "alOutline.codeCleanupActions": [
        "AddToolTips",
        "FixKeywordsCase",
        "FixIdentifiersCase",
        "SortVariables",
        "AddApplicationAreas",
        "SortTableFields",
        "AddMissingParentheses",
        "RemoveBeginEnd",
        "RemoveUnusedVariables"
    ],
    "workbench.editor.enablePreview": true,
    "CRS.ObjectNamePrefix": "KNH",
    //"CRS.OnSaveAlFileAction": "Rename",
    "CRS.FileNamePattern": "<ObjectName>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePatternExtensions": "<ObjectName>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePatternPageCustomizations": "<ObjectName>.<ObjectTypeShortPascalCase>.al",
    "github.copilot.preferredAccount": "KeithNHow",
    "github.copilot.chat.experimental.startDebugging.enabled": true,
    "github.copilot.chat.experimental.inlineChatCompletionTrigger.enabled": true,
    "github.copilot.chat.experimental.generateTests.codeLens": true,
    "github.copilot.chat.experimental.temporalContext.enabled": true,
    "github.copilot.chat.scopeSelection": true,
    "github.copilot.advanced": {
    "authProvider": "github"
    },
}